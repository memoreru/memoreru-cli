{
  "name": "@memoreru-sdk/cli",
  "version": "0.4.0",
  "description": "Memoreru CLI — sync local files with Memoreru",
  "type": "module",
  "bin": {
    "memoreru": "./dist/bin/memoreru.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist/",
    "schemas/",
    "skills/",
